// code to be execiuted when the condition is true
}

void main(){
  
  // if statement 
  var salary = 60000;
  if(salary > 50000){
    print('you got the promotion');  
  }
}

output:
you got the promotion

when in condition salary is greater in the condition according to given salary then nothing to be print and we need else statement 

IF_ELSE STATEMENT...
SYNTAX:

if(condition){
// code to be executed when the condition is true
}else{
// code to be executed when the condtion is false
}

void main(){
  
  // if_else statement 
  var salary = 60000;
  if(salary > 70000){
    print('you got the promotion');  
  }else{
    print('you need to work hard');
  }
}

output:
you need to work hard


